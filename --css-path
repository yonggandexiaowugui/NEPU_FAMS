        /* === Particle Field === */
        .particles {
            position: absolute;
            inset: 0;
            z-index: 1;
            overflow: hidden;
        }

        .particles span {
            position: absolute;
            left: var(--x);
            top: var(--y);
            width: var(--size);
            height: var(--size);
            background: var(--color-primary);
            border-radius: 50%;
            opacity: var(--opacity);
            box-shadow: 0 0 6px var(--color-primary-glow);
            animation: particle-float var(--duration) linear var(--delay) infinite;
        }

        @keyframes particle-float {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }
            10% {
                opacity: var(--opacity);
            }
            50% {
                transform: translate(80px, -120px) scale(1.3);
            }
            90% {
                opacity: var(--opacity);
            }
            100% {
                transform: translate(160px, -240px) scale(0.5);
                opacity: 0;
            }
        }

        /* === Hologram Area (Center-Left) === */
        .hologram-area {
            position: absolute;
            left: 12%;
            top: 50%;
            transform: translateY(-50%);
            width: 280px;
            height: 280px;
            z-index: 2;
        }

        /* === Glowing Ring === */
        .hologram-ring {
            position: absolute;
            inset: -20px;
            border-radius: 50%;
            border: 2px solid rgba(0, 229, 255, 0.3);
            box-shadow:
                0 0 15px rgba(0, 229, 255, 0.2),
                0 0 30px rgba(0, 229, 255, 0.1),
                inset 0 0 15px rgba(0, 229, 255, 0.1);
            animation: ring-rotate 12s linear infinite;
        }

        @keyframes ring-rotate {
            0% { transform: rotateY(0deg); }
            100% { transform: rotateY(360deg); }
        }

        /* Orbit Data Stream Lines */
        .orbit-line {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 140px;
            height: 2px;
            transform-origin: 0 50%;
            overflow: hidden;
        }

        .orbit-line::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 40px;
            height: 100%;
            background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
            animation: orbit-flow 3s linear infinite;
        }

        .orbit-line-1 {
            transform: rotate(0deg);
        }
        .orbit-line-1::after {
            animation-duration: 3s;
        }

        .orbit-line-2 {
            transform: rotate(120deg);
        }
        .orbit-line-2::after {
            animation-duration: 4s;
            animation-delay: -1.5s;
        }

        .orbit-line-3 {
            transform: rotate(240deg);
        }
        .orbit-line-3::after {
            animation-duration: 3.5s;
            animation-delay: -0.8s;
        }

        @keyframes orbit-flow {
            0% { left: -40px; }
            100% { left: 200px; }
        }

        /* === Hologram Emblem (Shield / CSS Art) === */
        .hologram-emblem {
            position: absolute;
            inset: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: emblem-float 6s ease-in-out infinite;
        }

        @keyframes emblem-float {
            0%, 100% { transform: translateY(0) rotateY(0deg); }
            25% { transform: translateY(-8px) rotateY(15deg); }
            50% { transform: translateY(0) rotateY(0deg); }
            75% { transform: translateY(8px) rotateY(-15deg); }
        }

        .shield {
            position: relative;
            width: 120px;
            height: 140px;
            animation: shield-rotate 20s linear infinite;
            filter: drop-shadow(0 0 20px rgba(0, 229, 255, 0.6)) drop-shadow(0 0 40px rgba(0, 229, 255, 0.3));
