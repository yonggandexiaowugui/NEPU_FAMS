        transform: translateY(-2px);
      }

      .neon-btn-danger-lg {
        background: linear-gradient(135deg, rgba(255, 46, 99, 0.2), rgba(255, 46, 99, 0.1));
        border: 1px solid var(--color-danger);
        color: var(--color-danger);
        padding: 10px 28px;
        border-radius: var(--radius-md);
        font-weight: var(--font-weight-semibold);
        cursor: pointer;
        transition: all var(--transition-normal);
        box-shadow: var(--glow-danger);
        text-shadow: 0 0 8px rgba(255, 46, 99, 0.5);
        font-size: var(--font-size-md);
      }

      .neon-btn-danger-lg:hover {
        background: linear-gradient(135deg, rgba(255, 46, 99, 0.3), rgba(255, 46, 99, 0.2));
        box-shadow: 0 0 15px rgba(255, 46, 99, 0.6), 0 0 30px rgba(255, 46, 99, 0.3);
        transform: translateY(-2px);
      }

      /* === Back Button === */
      .back-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-sm);
        color: var(--color-text-secondary);
        text-decoration: none;
        font-size: var(--font-size-base);
        transition: all var(--transition-fast);
        cursor: pointer;
        padding: var(--space-xs) var(--space-sm);
        border-radius: var(--radius-sm);
        margin-right: var(--space-sm);
