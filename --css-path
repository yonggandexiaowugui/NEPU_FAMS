      }

      /* ---- Main Content ---- */
      .main-content {
        margin-left: var(--sidebar-width);
        padding-top: var(--header-height);
        min-height: 100vh;
      }

      .content-inner {
        padding: var(--space-xl);
      }

      /* ---- KPI Cards ---- */
      .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-lg);
        margin-bottom: var(--space-xl);
      }

      .kpi-card {
        position: relative;
        padding: var(--space-lg);
        overflow: hidden;
        transition: all var(--transition-normal);
        cursor: default;
      }

      .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-float);
      }

      .kpi-icon {
        position: absolute;
        right: var(--space-md);
        top: var(--space-md);
        font-size: 32px;
        opacity: 0.15;
      }

      .kpi-label {
        font-size: var(--font-size-sm);
        color: var(--color-text-tertiary);
        letter-spacing: var(--letter-spacing-wide);
        margin-bottom: var(--space-sm);
      }

      .kpi-value {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-3xl);
        font-weight: var(--font-weight-bold);
        line-height: var(--line-height-tight);
      }

      .kpi-value.neon-blue {
        color: var(--color-primary);
        text-shadow: 0 0 12px rgba(0,229,255,0.6), 0 0 24px rgba(0,229,255,0.3);
      }

      .kpi-value.neon-gold {
        color: var(--color-secondary);
        text-shadow: 0 0 12px rgba(255,184,0,0.6), 0 0 24px rgba(255,184,0,0.3);
      }

      .kpi-value.neon-orange {
        color: var(--color-warning);
        text-shadow: 0 0 12px rgba(255,138,0,0.6), 0 0 24px rgba(255,138,0,0.3);
        animation: pulse-orange 2s ease-in-out infinite;
      }

      .kpi-value.neon-red {
        color: var(--color-danger);
        text-shadow: 0 0 12px rgba(255,46,99,0.6), 0 0 24px rgba(255,46,99,0.3);
        animation: pulse-red 2s ease-in-out infinite;
      }

      @keyframes pulse-orange {
        0%, 100% { text-shadow: 0 0 8px rgba(255,138,0,0.4), 0 0 16px rgba(255,138,0,0.2); }
        50% { text-shadow: 0 0 16px rgba(255,138,0,0.8), 0 0 32px rgba(255,138,0,0.4); }
      }

      @keyframes pulse-red {
        0%, 100% { text-shadow: 0 0 8px rgba(255,46,99,0.4), 0 0 16px rgba(255,46,99,0.2); }
        50% { text-shadow: 0 0 16px rgba(255,46,99,0.8), 0 0 32px rgba(255,46,99,0.4); }
      }

      .kpi-card::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 2px;
      }

      .kpi-card.kpi-blue::after { background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent); }
      .kpi-card.kpi-gold::after { background: linear-gradient(90deg, transparent, var(--color-secondary-dim), transparent); }
      .kpi-card.kpi-orange::after { background: linear-gradient(90deg, transparent, var(--color-warning-dim), transparent); }
      .kpi-card.kpi-red::after { background: linear-gradient(90deg, transparent, var(--color-danger-dim), transparent); }

      /* ---- Two Column Layout ---- */
      .two-col {
        display: grid;
        gap: var(--space-lg);
        margin-bottom: var(--space-xl);
      }

      .two-col-60-40 { grid-template-columns: 3fr 2fr; }
      .two-col-50-50 { grid-template-columns: 1fr 1fr; }

      /* ---- Donut Chart ---- */
      .chart-panel {
        padding: var(--space-lg);
      }

      .panel-title {
        font-family: var(--font-family-display);
        font-size: var(--font-size-md);
        color: var(--color-primary);
        letter-spacing: var(--letter-spacing-wide);
        margin-bottom: var(--space-lg);
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid var(--color-border-subtle);
      }

      .donut-container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2xl);
        padding: var(--space-md) 0;
      }

      .donut-wrapper {
        position: relative;
        width: 200px;
        height: 200px;
      }

      .donut-ring {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        position: relative;
        animation: donut-rotate 20s linear infinite;
        /* 5 segments: 在用 45%, 闲置 25%, 维修中 12%, 已报废 10%, 盘亏 8% */
        background: conic-gradient(
          var(--color-warning) 0deg 162deg,
          var(--color-success) 162deg 252deg,
          var(--color-secondary) 252deg 295.2deg,
          var(--color-danger) 295.2deg 331.2deg,
          var(--color-text-tertiary) 331.2deg 360deg
        );
      }

      .donut-ring::before {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: var(--color-bg-primary);
        box-shadow: inset 0 0 20px rgba(0, 229, 255, 0.05);
      }

      .donut-center {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 2;
      }

      .donut-center .total-num {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-2xl);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        text-shadow: 0 0 10px rgba(0,229,255,0.5);
      }

      .donut-center .total-label {
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        letter-spacing: var(--letter-spacing-wider);
      }

      @keyframes donut-rotate {
        0% { filter: drop-shadow(0 0 6px rgba(0,229,255,0.2)); }
        25% { filter: drop-shadow(0 0 12px rgba(0,229,255,0.4)); }
        50% { filter: drop-shadow(0 0 6px rgba(0,229,255,0.2)); }
        75% { filter: drop-shadow(0 0 12px rgba(255,184,0,0.3)); }
        100% { filter: drop-shadow(0 0 6px rgba(0,229,255,0.2)); }
      }

      .donut-legend {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .legend-item {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
      }

      .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        flex-shrink: 0;
      }

      .legend-name { min-width: 48px; }

      .legend-val {
        font-family: var(--font-family-mono);
        color: var(--color-text-primary);
        margin-left: auto;
        padding-left: 12px;
      }

      /* ---- Approval List ---- */
      .approval-list {
        padding: var(--space-lg);
      }

      .approval-item {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: 10px var(--space-md);
        margin-bottom: var(--space-sm);
        background: rgba(13, 19, 33, 0.5);
        border-radius: var(--radius-md);
        border-left: 3px solid var(--color-warning);
        transition: all var(--transition-fast);
        cursor: pointer;
      }

      .approval-item:hover {
        background: rgba(0, 229, 255, 0.05);
        border-left-color: var(--color-primary);
      }

      .approval-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--color-danger);
        box-shadow: 0 0 6px rgba(255,46,99,0.8);
        animation: breathe 2s ease-in-out infinite;
        flex-shrink: 0;
      }

      .approval-info { flex: 1; min-width: 0; }

      .approval-applicant {
        font-size: var(--font-size-sm);
        color: var(--color-text-primary);
        font-weight: var(--font-weight-medium);
      }

      .approval-asset {
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .approval-time {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        flex-shrink: 0;
      }

      /* ---- Sparkline Chart ---- */
      .trend-panel {
        padding: var(--space-lg);
      }

      .sparkline-svg {
        width: 100%;
        height: 180px;
        display: block;
      }

      .sparkline-grid line {
        stroke: rgba(0, 229, 255, 0.06);
        stroke-width: 1;
      }

      .sparkline-line {
        fill: none;
        stroke: var(--color-primary);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        filter: url(#neon-glow);
      }

      .sparkline-area {
        opacity: 0.15;
      }

      .sparkline-dot {
        fill: var(--color-primary);
        filter: url(#neon-glow);
      }

      /* ---- Operation Log Console ---- */
      .log-console {
        padding: var(--space-lg);
        position: relative;
        overflow: hidden;
      }

      .log-console::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 30px;
        background: linear-gradient(var(--color-bg-primary), transparent);
        z-index: 2;
        pointer-events: none;
      }

      .console-header {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        margin-bottom: var(--space-md);
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid var(--color-border-subtle);
      }

      .console-dots {
        display: flex;
        gap: 6px;
      }

      .console-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
      }

      .console-dot.red { background: var(--color-danger); }
      .console-dot.yellow { background: var(--color-secondary); }
      .console-dot.green { background: var(--color-success); }

      .console-title {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        margin-left: var(--space-sm);
      }

      .log-entries {
        background: rgba(0, 0, 0, 0.3);
        border-radius: var(--radius-md);
        padding: var(--space-md);
        max-height: 200px;
        overflow-y: auto;
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        line-height: 1.8;
      }

      .log-line {
        display: flex;
        align-items: flex-start;
        gap: var(--space-sm);
        opacity: 0;
        animation: log-fadein 0.5s ease forwards;
      }

      .log-line:nth-child(1) { animation-delay: 0.1s; }
      .log-line:nth-child(2) { animation-delay: 0.3s; }
      .log-line:nth-child(3) { animation-delay: 0.5s; }
      .log-line:nth-child(4) { animation-delay: 0.7s; }
      .log-line:nth-child(5) { animation-delay: 0.9s; }
      .log-line:nth-child(6) { animation-delay: 1.1s; }
      .log-line:nth-child(7) { animation-delay: 1.3s; }
      .log-line:nth-child(8) { animation-delay: 1.5s; }
      .log-line:nth-child(9) { animation-delay: 1.7s; }
      .log-line:nth-child(10) { animation-delay: 1.9s; }

      @keyframes log-fadein {
        from { opacity: 0; transform: translateX(-8px); }
        to { opacity: 1; transform: translateX(0); }
      }

      .log-indicator {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 7px;
      }

      .log-indicator.add { background: var(--color-primary); box-shadow: 0 0 4px rgba(0,229,255,0.6); }
      .log-indicator.modify { background: var(--color-success); box-shadow: 0 0 4px rgba(0,255,148,0.6); }
      .log-indicator.delete { background: var(--color-warning); box-shadow: 0 0 4px rgba(255,184,0,0.6); }
      .log-indicator.warning { background: var(--color-danger); box-shadow: 0 0 4px rgba(255,46,99,0.6); }

      .log-time {
        color: var(--color-text-tertiary);
        flex-shrink: 0;
      }

      .log-msg { color: var(--color-success); }
      .log-msg.info { color: var(--color-primary); }
      .log-msg.warn { color: var(--color-warning); }
      .log-msg.error { color: var(--color-danger); }
    </style>
</body>
