        align-items: flex-start;
        justify-content: space-between;
        position: relative;
        padding: var(--space-lg) var(--space-xl);
        gap: 0;
      }

      .timeline-node {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
        flex: 0 0 auto;
        min-width: 80px;
      }

      .timeline-node-circle {
        width: 44px;
        height: 44px;
        border-radius: var(--radius-full);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: var(--space-sm);
        position: relative;
        transition: all var(--transition-normal);
      }

      .timeline-node-circle.completed {
        background: rgba(255, 184, 0, 0.15);
        border: 2px solid var(--color-secondary);
        box-shadow: 0 0 12px rgba(255, 184, 0, 0.5), 0 0 24px rgba(255, 184, 0, 0.2);
        color: var(--color-secondary);
      }

      .timeline-node-circle.current {
        background: rgba(0, 229, 255, 0.15);
        border: 2px solid var(--color-primary);
        animation: pulse-glow 2s ease-in-out infinite;
        color: var(--color-primary);
      }

      .timeline-node-circle.pending {
        background: rgba(232, 236, 244, 0.06);
        border: 2px solid rgba(232, 236, 244, 0.15);
        color: var(--color-text-disabled);
      }

      .timeline-node-label {
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
        text-align: center;
        white-space: nowrap;
      }

      .timeline-node-label.completed {
        color: var(--color-secondary);
        text-shadow: 0 0 6px rgba(255, 184, 0, 0.4);
      }

      .timeline-node-label.current {
        color: var(--color-primary);
        text-shadow: 0 0 6px rgba(0, 229, 255, 0.4);
      }

      .timeline-node-label.pending {
        color: var(--color-text-disabled);
      }

      .timeline-connector {
        flex: 1;
        height: 3px;
        margin-top: 22px;
        border-radius: 2px;
        position: relative;
        overflow: hidden;
        z-index: 1;
      }

      .timeline-connector.completed {
        background: rgba(255, 184, 0, 0.3);
        background-size: 200% 100%;
        background-image: linear-gradient(90deg, var(--color-secondary), var(--color-primary), var(--color-secondary));
        animation: neon-flow 3s ease infinite;
      }

      .timeline-connector.pending {
        background: rgba(232, 236, 244, 0.08);
      }

      .timeline-connector.active-pulse {
        background: rgba(0, 229, 255, 0.2);
        background-size: 200% 100%;
        background-image: linear-gradient(90deg, var(--color-secondary), var(--color-primary), rgba(0, 229, 255, 0.1));
        animation: neon-flow 2s ease infinite;
      }

      /* === Timeline Detail Cards === */
      .timeline-detail-card {
        padding: var(--space-lg);
        margin-bottom: var(--space-md);
        position: relative;
        overflow: hidden;
      }

      .timeline-detail-card::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
      }

      .timeline-detail-card.gold-border::before {
        background: var(--color-secondary);
        box-shadow: 0 0 8px rgba(255, 184, 0, 0.5);
      }

      .timeline-detail-card.blue-border::before {
        background: var(--color-primary);
        box-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
        animation: breathe 2s ease-in-out infinite;
      }

      .detail-row {
        display: flex;
        align-items: flex-start;
        margin-bottom: var(--space-sm);
        font-size: var(--font-size-base);
      }

      .detail-row:last-child {
        margin-bottom: 0;
      }

      .detail-label {
        color: var(--color-text-tertiary);
        min-width: 80px;
        flex-shrink: 0;
      }

      .detail-value {
        color: var(--color-text-primary);
      }

      .detail-opinion {
        color: var(--color-text-secondary);
        line-height: var(--line-height-relaxed);
        padding: var(--space-sm) var(--space-md);
        background: rgba(0, 229, 255, 0.03);
        border-radius: var(--radius-sm);
        border-left: 2px solid rgba(232, 236, 244, 0.08);
        margin-top: var(--space-sm);
      }

      /* === Asset Info Grid === */
      .asset-info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-md);
      }

      .asset-info-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
      }

      .asset-info-item .info-label {
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        letter-spacing: var(--letter-spacing-wide);
      }

      .asset-info-item .info-value {
        font-size: var(--font-size-md);
        color: var(--color-text-primary);
        font-weight: var(--font-weight-medium);
      }

      /* === Status Badge === */
      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: var(--space-xs);
        padding: 4px 12px;
        border-radius: var(--radius-full);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
      }

      .status-badge.warning {
        background: var(--color-warning-faint);
        border: 1px solid rgba(255, 138, 0, 0.3);
        color: var(--color-warning);
        text-shadow: 0 0 6px rgba(255, 138, 0, 0.4);
        animation: pulse-warning 2s ease-in-out infinite;
      }

      .status-badge.success {
        background: var(--color-success-faint);
        border: 1px solid rgba(0, 255, 148, 0.3);
        color: var(--color-success);
        text-shadow: 0 0 6px rgba(0, 255, 148, 0.4);
      }

      .status-badge .pulse-dot {
        width: 6px;
        height: 6px;
        border-radius: var(--radius-full);
        background: currentColor;
        animation: breathe 1.5s ease-in-out infinite;
      }

      @keyframes pulse-warning {
        0%, 100% { box-shadow: 0 0 6px rgba(255, 138, 0, 0.3); }
        50% { box-shadow: 0 0 16px rgba(255, 138, 0, 0.6), 0 0 32px rgba(255, 138, 0, 0.2); }
      }

      /* === Action Area === */
      .reject-textarea {
        width: 100%;
        min-height: 80px;
        background: var(--color-bg-input);
        border: 1px solid var(--color-border-subtle);
        border-radius: var(--radius-md);
        color: var(--color-text-primary);
        padding: var(--space-md);
