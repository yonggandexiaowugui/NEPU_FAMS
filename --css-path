      /* Log Table */
      .log-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
      }

      .log-table thead th {
        background: rgba(0, 229, 255, 0.05);
        border-bottom: 1px solid rgba(0, 229, 255, 0.12);
        color: var(--color-primary);
        font-weight: var(--font-weight-semibold);
        font-size: var(--font-size-xs);
        text-transform: uppercase;
        letter-spacing: var(--letter-spacing-wider);
        padding: 14px 16px;
        text-align: left;
        font-family: var(--font-family-mono);
        position: sticky;
        top: 0;
        z-index: 2;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      .log-table tbody tr {
        border-bottom: 1px solid rgba(0, 229, 255, 0.04);
        transition: all var(--transition-fast);
        opacity: 0;
        animation: log-row-fadein 0.4s ease forwards;
      }

      .log-table tbody tr:hover {
        background: rgba(0, 229, 255, 0.04);
        box-shadow: inset 0 0 30px rgba(0, 229, 255, 0.02);
      }

      .log-table tbody tr:last-child {
        border-bottom: none;
      }

      .log-table tbody td {
        padding: 12px 16px;
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
        vertical-align: middle;
      }

      /* Staggered fade-in */
      .log-table tbody tr:nth-child(1) { animation-delay: 0.05s; }
      .log-table tbody tr:nth-child(2) { animation-delay: 0.1s; }
      .log-table tbody tr:nth-child(3) { animation-delay: 0.15s; }
      .log-table tbody tr:nth-child(4) { animation-delay: 0.2s; }
      .log-table tbody tr:nth-child(5) { animation-delay: 0.25s; }
      .log-table tbody tr:nth-child(6) { animation-delay: 0.3s; }
      .log-table tbody tr:nth-child(7) { animation-delay: 0.35s; }
      .log-table tbody tr:nth-child(8) { animation-delay: 0.4s; }
      .log-table tbody tr:nth-child(9) { animation-delay: 0.45s; }
      .log-table tbody tr:nth-child(10) { animation-delay: 0.5s; }
      .log-table tbody tr:nth-child(11) { animation-delay: 0.55s; }
      .log-table tbody tr:nth-child(12) { animation-delay: 0.6s; }
      .log-table tbody tr:nth-child(13) { animation-delay: 0.65s; }
      .log-table tbody tr:nth-child(14) { animation-delay: 0.7s; }
      .log-table tbody tr:nth-child(15) { animation-delay: 0.75s; }
      .log-table tbody tr:nth-child(16) { animation-delay: 0.8s; }
      .log-table tbody tr:nth-child(17) { animation-delay: 0.85s; }
      .log-table tbody tr:nth-child(18) { animation-delay: 0.9s; }

      @keyframes log-row-fadein {
        from { opacity: 0; transform: translateX(-6px); }
        to { opacity: 1; transform: translateX(0); }
      }

      /* Log dot indicators */
      .log-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
      }

      .log-dot.add { background: var(--color-success); box-shadow: 0 0 6px rgba(0,255,148,0.6); }
      .log-dot.modify { background: var(--color-primary); box-shadow: 0 0 6px rgba(0,229,255,0.6); }
      .log-dot.delete { background: var(--color-danger); box-shadow: 0 0 6px rgba(255,46,99,0.6); }
      .log-dot.approve { background: var(--color-secondary); box-shadow: 0 0 6px rgba(255,184,0,0.6); }
      .log-dot.export { background: #00E5FF; box-shadow: 0 0 6px rgba(0,229,255,0.6); }
      .log-dot.login { background: #B388FF; box-shadow: 0 0 6px rgba(179,136,255,0.5); }

      /* Time styling */
      .log-time {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: rgba(0, 255, 148, 0.7);
        text-shadow: 0 0 4px rgba(0, 255, 148, 0.15);
        white-space: nowrap;
      }

      /* Operation type badge */
      .log-type-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: var(--radius-full);
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-medium);
        white-space: nowrap;
        letter-spacing: 0.03em;
      }

      .log-type-badge.add {
        background: var(--color-success-faint);
        border: 1px solid rgba(0, 255, 148, 0.3);
        color: var(--color-success);
        text-shadow: 0 0 4px rgba(0, 255, 148, 0.3);
