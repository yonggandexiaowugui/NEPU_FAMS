      .terminal-status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--color-success);
        box-shadow: 0 0 6px rgba(0, 255, 148, 0.6);
        animation: breathe 2s ease-in-out infinite;
