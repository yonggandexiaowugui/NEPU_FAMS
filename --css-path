      /* Scan line animation */
      .terminal-panel::after {
        content: '';
        position: absolute;
        left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent 0%, rgba(0, 229, 255, 0.08) 20%, rgba(0, 229, 255, 0.15) 50%, rgba(0, 229, 255, 0.08) 80%, transparent 100%);
        animation: terminal-scan 8s linear infinite;
        pointer-events: none;
        z-index: 3;
      }

      @keyframes terminal-scan {
        0% { top: 0; }
        100% { top: 100%; }
