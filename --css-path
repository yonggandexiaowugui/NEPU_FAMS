            bottom: 0;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg,
                transparent,
                var(--color-primary),
                var(--color-primary),
                transparent);
            transition: width 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            box-shadow: 0 0 10px rgba(0, 229, 255, 0.6);
        }

        .input-wrapper:focus-within .input-focus-line {
            width: 100%;
        }

        /* === Form Options === */
        .form-options {
            display: flex;
            align-items: center;
            margin-top: -4px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            user-select: none;
        }

        .neon-checkbox {
            display: none;
        }

        .checkbox-custom {
            position: relative;
            width: 18px;
            height: 18px;
            border: 1px solid rgba(0, 229, 255, 0.3);
            border-radius: 4px;
            background: rgba(13, 19, 33, 0.8);
            transition: all var(--transition-normal);
            flex-shrink: 0;
        }

        .checkbox-custom::after {
            content: '';
            position: absolute;
            top: 2px;
            left: 6px;
            width: 4px;
            height: 8px;
            border: solid var(--color-primary);
            border-width: 0 2px 2px 0;
            transform: rotate(45deg) scale(0);
            transition: transform var(--transition-fast);
        }

        .neon-checkbox:checked + .checkbox-custom {
            border-color: var(--color-primary);
            background: rgba(0, 229, 255, 0.1);
            box-shadow: 0 0 8px rgba(0, 229, 255, 0.3);
        }

        .neon-checkbox:checked + .checkbox-custom::after {
            transform: rotate(45deg) scale(1);
        }

        .checkbox-label {
            font-size: 13px;
            color: var(--color-text-secondary);
            transition: color var(--transition-fast);
        }

        .remember-me:hover .checkbox-label {
            color: var(--color-text-primary);
        }

        .remember-me:hover .checkbox-custom {
            border-color: rgba(0, 229, 255, 0.5);
            box-shadow: 0 0 6px rgba(0, 229, 255, 0.2);
        }

        /* === Login Button === */
        .login-btn {
            position: relative;
            width: 100%;
            padding: 16px 24px;
            margin-top: 8px;
            background: linear-gradient(135deg,
                rgba(0, 229, 255, 0.2),
                rgba(100, 60, 255, 0.2),
                rgba(0, 229, 255, 0.15));
            border: 1px solid rgba(0, 229, 255, 0.5);
            border-radius: 8px;
            color: var(--color-primary);
            font-family: var(--font-family-display);
            font-size: 16px;
            font-weight: 700;
            letter-spacing: 0.3em;
            cursor: pointer;
            overflow: hidden;
            transition: all var(--transition-normal);
            animation: btn-breathe 3s ease-in-out infinite;
        }

        .login-btn:hover {
            background: linear-gradient(135deg,
                rgba(0, 229, 255, 0.35),
                rgba(100, 60, 255, 0.35),
                rgba(0, 229, 255, 0.25));
            box-shadow:
                0 0 20px rgba(0, 229, 255, 0.4),
                0 0 40px rgba(0, 229, 255, 0.15),
                0 0 60px rgba(100, 60, 255, 0.1);
            transform: scale(1.02);
        }

        .login-btn:active {
            transform: scale(0.98);
        }

        @keyframes btn-breathe {
            0%, 100% {
                box-shadow:
                    0 0 10px rgba(0, 229, 255, 0.2),
                    0 0 20px rgba(0, 229, 255, 0.1);
            }
            50% {
                box-shadow:
                    0 0 15px rgba(0, 229, 255, 0.4),
                    0 0 30px rgba(0, 229, 255, 0.2),
                    0 0 50px rgba(100, 60, 255, 0.1);
            }
        }

        /* Ripple Effect */
        .btn-ripple {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 40px;
            height: 40px;
            margin-top: -20px;
            margin-left: -20px;
            border-radius: 50%;
            background: rgba(0, 229, 255, 0.4);
            transform: scale(0);
            opacity: 0;
            pointer-events: none;
        }

        .login-btn:active .btn-ripple {
            animation: ripple-wave 0.8s ease-out;
        }

        .btn-ripple-2 {
            animation-delay: 0.15s;
        }

        @keyframes ripple-wave {
            0% {
                transform: scale(0);
                opacity: 0.6;
            }
            100% {
                transform: scale(12);
                opacity: 0;
            }
        }

        .btn-text {
            position: relative;
            z-index: 2;
            text-shadow:
                0 0 10px rgba(0, 229, 255, 0.6),
                0 0 20px rgba(0, 229, 255, 0.3);
        }

        /* === Login Footer === */
        .login-footer {
            text-align: center;
            margin-top: 28px;
        }

        .footer-line {
            width: 200px;
            height: 1px;
            margin: 0 auto 14px;
            background: linear-gradient(90deg,
                transparent,
                rgba(255, 184, 0, 0.2),
