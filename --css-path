    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        background:
          repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,229,255,0.03) 39px, rgba(0,229,255,0.03) 40px),
          repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,229,255,0.03) 39px, rgba(0,229,255,0.03) 40px),
          var(--color-bg-primary);
        background-attachment: fixed;
      }

      /* ---- Sidebar ---- */
      .sidebar {
        position: fixed;
        left: 0; top: 0;
        width: var(--sidebar-width);
        height: 100vh;
        background: var(--sidebar-bg);
        border-right: 1px solid var(--color-border-glass);
        z-index: var(--z-sidebar);
        display: flex;
        flex-direction: column;
        backdrop-filter: var(--glass-blur-heavy);
        -webkit-backdrop-filter: var(--glass-blur-heavy);
      }

      .sidebar-logo {
        padding: var(--space-lg);
        text-align: center;
        border-bottom: 1px solid var(--color-border-subtle);
        position: relative;
        overflow: hidden;
      }

      .sidebar-logo::after {
        content: '';
        position: absolute;
        bottom: 0; left: 10%; right: 10%;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent);
        animation: breathe 3s ease-in-out infinite;
      }

      .logo-text {
        font-family: var(--font-family-display);
        font-size: 28px;
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.15em;
        background: linear-gradient(180deg, #E8ECF4 0%, #8899AA 40%, #556677 60%, #AABBCC 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: none;
        filter: drop-shadow(0 0 12px rgba(0,229,255,0.4));
        animation: logo-breathe 4s ease-in-out infinite;
        position: relative;
      }

      @keyframes logo-breathe {
        0%, 100% { filter: drop-shadow(0 0 8px rgba(0,229,255,0.3)); }
        50% { filter: drop-shadow(0 0 20px rgba(0,229,255,0.6)) drop-shadow(0 0 40px rgba(0,229,255,0.2)); }
      }

      .logo-sub {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        letter-spacing: var(--letter-spacing-wider);
        margin-top: 4px;
      }

      /* ---- Nav ---- */
      .sidebar-nav {
        flex: 1;
        padding: var(--space-sm) 0;
        overflow-y: auto;
      }

      .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 20px;
        margin: 2px 8px;
        border-radius: var(--radius-md);
        color: var(--color-text-secondary);
        font-size: var(--font-size-md);
        cursor: pointer;
        transition: all var(--transition-normal);
        position: relative;
        text-decoration: none;
      }

      .nav-item:hover {
        color: var(--color-text-primary);
        background: rgba(0, 229, 255, 0.06);
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.08), inset 0 0 15px rgba(0, 229, 255, 0.03);
      }

      .nav-item.active {
        color: var(--color-primary);
        background: linear-gradient(90deg, rgba(0, 229, 255, 0.15), rgba(0, 229, 255, 0.05));
        box-shadow: 0 0 20px rgba(0, 229, 255, 0.1), inset 0 0 20px rgba(0, 229, 255, 0.05);
      }

      .nav-item.active::before {
        content: '';
        position: absolute;
        left: 0; top: 6px; bottom: 6px;
        width: 3px;
        border-radius: 0 3px 3px 0;
        background: var(--color-primary);
        box-shadow: 0 0 8px rgba(0, 229, 255, 0.8), 0 0 16px rgba(0, 229, 255, 0.4);
        animation: breathe 3s ease-in-out infinite;
      }

      .nav-icon {
        font-size: 16px;
        width: 22px;
        text-align: center;
        flex-shrink: 0;
      }

      /* ---- Header ---- */
      .top-header {
        position: fixed;
        left: var(--sidebar-width);
        right: 0; top: 0;
        height: var(--header-height);
        background: rgba(8, 12, 22, 0.75);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border-bottom: 1px solid var(--color-border-glass);
        z-index: var(--z-header);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 var(--space-xl);
      }

      .header-left {
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      .header-title {
        font-family: var(--font-family-display);
        font-size: var(--font-size-md);
        color: var(--color-text-primary);
        letter-spacing: var(--letter-spacing-wide);
      }

      .header-breadcrumb {
        font-size: var(--font-size-sm);
        color: var(--color-text-tertiary);
      }

      .header-breadcrumb span {
        color: var(--color-text-secondary);
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: var(--space-lg);
      }

      .notif-bell {
        position: relative;
        cursor: pointer;
        color: var(--color-text-secondary);
        transition: color var(--transition-fast);
      }
      .notif-bell:hover { color: var(--color-primary); }
      .notif-badge {
        position: absolute;
        top: -3px; right: -4px;
        width: 8px; height: 8px;
        background: var(--color-danger);
        border-radius: 50%;
        box-shadow: 0 0 6px rgba(255,46,99,0.8);
        animation: breathe 2s ease-in-out infinite;
      }

      .role-tag {
        padding: 4px 12px;
        border-radius: var(--radius-full);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-medium);
        color: var(--color-secondary);
        border: 1px solid rgba(255, 184, 0, 0.3);
        background: rgba(255, 184, 0, 0.08);
        box-shadow: 0 0 8px rgba(255,184,0,0.2);
        animation: breathe 4s ease-in-out infinite;
      }

      .avatar-circle {
        width: 34px; height: 34px;
        border-radius: 50%;
        border: 2px solid var(--color-primary);
        box-shadow: 0 0 10px rgba(0,229,255,0.4);
        background: linear-gradient(135deg, rgba(0,229,255,0.2), rgba(0,229,255,0.05));
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--color-primary);
        font-family: var(--font-family-display);
        font-size: 14px;
        font-weight: var(--font-weight-bold);
        cursor: pointer;
        transition: all var(--transition-normal);
      }
      .avatar-circle:hover {
        box-shadow: 0 0 16px rgba(0,229,255,0.6), 0 0 32px rgba(0,229,255,0.2);
      }

      /* ---- Main Content ---- */
      .main-content {
        margin-left: var(--sidebar-width);
        padding-top: var(--header-height);
        min-height: 100vh;
      }

      .content-inner {
        padding: var(--space-xl);
      }

      /* ---- Filter Bar ---- */
      .filter-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-md);
        padding: var(--space-lg);
      }

