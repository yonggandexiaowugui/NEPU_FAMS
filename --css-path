        width: 8px; height: 8px; border-radius: 50%;
        background: var(--color-danger);
        box-shadow: 0 0 6px rgba(255,46,99,0.8);
        animation: breathe 2s ease-in-out infinite;
      }

      .role-tag {
        padding: 4px 12px; border-radius: var(--radius-full);
        font-size: var(--font-size-sm); font-weight: var(--font-weight-medium);
        color: var(--color-secondary);
        border: 1px solid rgba(255, 184, 0, 0.3);
        background: rgba(255, 184, 0, 0.08);
        box-shadow: 0 0 8px rgba(255,184,0,0.2);
        animation: breathe 4s ease-in-out infinite;
      }

      .avatar-circle {
        width: 34px; height: 34px; border-radius: 50%;
        border: 2px solid var(--color-primary);
        box-shadow: 0 0 10px rgba(0,229,255,0.4);
        background: linear-gradient(135deg, rgba(0,229,255,0.2), rgba(0,229,255,0.05));
        display: flex; align-items: center; justify-content: center;
        color: var(--color-primary);
        font-family: var(--font-family-display);
        font-size: 14px; font-weight: var(--font-weight-bold);
        cursor: pointer; transition: all var(--transition-normal);
      }
      .avatar-circle:hover { box-shadow: 0 0 16px rgba(0,229,255,0.6), 0 0 32px rgba(0,229,255,0.2); }

      /* ---- Main Content ---- */
      .main-content {
        margin-left: var(--sidebar-width);
        padding-top: var(--header-height);
        min-height: 100vh;
      }

      .content-inner { padding: var(--space-xl); }

      /* ====== PANEL TITLES ====== */
      .panel-title {
        font-family: var(--font-family-display);
        font-size: var(--font-size-md);
        color: var(--color-primary);
        letter-spacing: var(--letter-spacing-wide);
        margin-bottom: var(--space-lg);
        padding-bottom: var(--space-sm);
        border-bottom: 1px solid var(--color-border-subtle);
      }

      /* ====== 1. REAL-TIME INVENTORY PANEL ====== */
      .realtime-panel {
        padding: var(--space-lg);
        margin-bottom: var(--space-xl);
        position: relative;
      }

      .realtime-title {
        font-family: var(--font-family-display);
        font-size: var(--font-size-lg);
        color: var(--color-primary);
        text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
        margin-bottom: var(--space-lg);
      }

      .realtime-title .title-sub {
        font-family: var(--font-family-body);
        font-size: var(--font-size-sm);
        color: var(--color-text-tertiary);
        text-shadow: none;
        margin-left: var(--space-sm);
      }

      .team-row {
        display: flex;
        gap: var(--space-lg);
        overflow-x: auto;
        padding-bottom: var(--space-sm);
      }

      .member-card {
        flex: 1;
        min-width: 180px;
        background: rgba(13, 19, 33, 0.5);
        border: 1px solid var(--color-border-subtle);
        border-radius: var(--radius-lg);
        padding: var(--space-md);
        transition: all var(--transition-normal);
        position: relative;
        overflow: hidden;
      }

      .member-card:hover {
        border-color: var(--color-border-hover);
        box-shadow: var(--glow-primary);
        transform: translateY(-2px);
      }

      .member-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent);
      }

      .member-header {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        margin-bottom: var(--space-sm);
      }

      .member-avatar {
        width: 40px; height: 40px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-family: var(--font-family-display);
        font-weight: var(--font-weight-bold);
        font-size: 14px;
        position: relative;
        color: var(--color-text-inverse);
      }

      .member-avatar.c1 { background: linear-gradient(135deg, #00E5FF, #00B8CC); }
      .member-avatar.c2 { background: linear-gradient(135deg, #FFB800, #FF8A00); }
      .member-avatar.c3 { background: linear-gradient(135deg, #00FF94, #00CC75); }
      .member-avatar.c4 { background: linear-gradient(135deg, #FF2E63, #CC1E4F); }
      .member-avatar.c5 { background: linear-gradient(135deg, #A855F7, #7C3AED); }

      .online-dot {
        position: absolute;
        bottom: 1px; right: 1px;
        width: 10px; height: 10px;
        border-radius: 50%;
        background: var(--color-success);
        border: 2px solid var(--color-bg-secondary);
        animation: online-breathe 2s ease-in-out infinite;
      }

      @keyframes online-breathe {
        0%, 100% {
          box-shadow: 0 0 4px rgba(0, 255, 148, 0.6);
        }
        50% {
          box-shadow: 0 0 12px rgba(0, 255, 148, 0.9), 0 0 24px rgba(0, 255, 148, 0.4);
        }
      }

      .offline-dot {
        background: var(--color-text-tertiary);
        animation: none;
        box-shadow: none;
      }

      .member-info { flex: 1; min-width: 0; }
      .member-name {
        font-size: var(--font-size-md);
        font-weight: var(--font-weight-semibold);
        color: var(--color-text-primary);
      }
      .member-role {
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
      }

      .member-count {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-sm);
        color: var(--color-secondary);
        margin-bottom: var(--space-sm);
        text-shadow: 0 0 6px rgba(255, 184, 0, 0.4);
      }

      .member-status {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: var(--font-size-xs);
        margin-bottom: var(--space-sm);
      }

      .member-status .status-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .member-status .status-dot.online {
        background: var(--color-success);
        box-shadow: 0 0 6px rgba(0, 255, 148, 0.8);
        animation: online-breathe 2s ease-in-out infinite;
      }

      .member-status .status-dot.offline {
        background: var(--color-text-tertiary);
      }

      .member-status .status-text.online { color: var(--color-success); }
      .member-status .status-text.offline { color: var(--color-text-tertiary); }

      /* ====== LIQUID PROGRESS BAR ====== */
      .liquid-bar-container {
        position: relative;
        width: 100%;
        height: 10px;
        background: rgba(0, 0, 0, 0.4);
        border-radius: var(--radius-full);
        overflow: hidden;
        border: 1px solid var(--color-border-subtle);
      }

      .liquid-bar-fill {
        position: absolute;
        left: 0; top: 0; bottom: 0;
        border-radius: var(--radius-full);
        background: linear-gradient(90deg, rgba(0, 229, 255, 0.6), rgba(0, 229, 255, 0.9));
        box-shadow: 0 0 8px rgba(0, 229, 255, 0.5), 0 0 16px rgba(0, 229, 255, 0.2);
        transition: width 1s ease;
        overflow: hidden;
      }

      .liquid-bar-fill.gold {
        background: linear-gradient(90deg, rgba(255, 184, 0, 0.6), rgba(255, 184, 0, 0.9));
        box-shadow: 0 0 8px rgba(255, 184, 0, 0.5), 0 0 16px rgba(255, 184, 0, 0.2);
      }

      .liquid-bar-fill.green {
        background: linear-gradient(90deg, rgba(0, 255, 148, 0.6), rgba(0, 255, 148, 0.9));
        box-shadow: 0 0 8px rgba(0, 255, 148, 0.5), 0 0 16px rgba(0, 255, 148, 0.2);
      }

      .liquid-bar-fill.gray {
        background: linear-gradient(90deg, rgba(232, 236, 244, 0.2), rgba(232, 236, 244, 0.35));
        box-shadow: none;
      }

      /* Wave effect at liquid surface */
      .liquid-wave {
        position: absolute;
        right: -4px; top: -4px; bottom: -4px;
        width: 16px;
        background: inherit;
        animation: liquid-wave 2s ease-in-out infinite;
        filter: brightness(1.3);
      }

      .liquid-bar-fill.gold .liquid-wave {
        box-shadow: 2px 0 8px rgba(255, 184, 0, 0.6);
      }

      .liquid-bar-fill.green .liquid-wave {
        box-shadow: 2px 0 8px rgba(0, 255, 148, 0.6);
      }

      /* ====== 2. INVENTORY TASK CARDS ====== */
      .task-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: var(--space-lg);
        margin-bottom: var(--space-xl);
      }

      .task-card {
        padding: var(--space-lg);
        transition: all var(--transition-normal);
        position: relative;
        overflow: hidden;
      }

      .task-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-float);
      }

      .task-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
      }

      .task-card.card-blue::before { background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent); }
      .task-card.card-gray::before { background: linear-gradient(90deg, transparent, rgba(232,236,244,0.2), transparent); }
      .task-card.card-green::before { background: linear-gradient(90deg, transparent, var(--color-success-dim), transparent); }

      .task-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: var(--space-sm);
      }

      .task-name {
        font-size: var(--font-size-md);
        font-weight: var(--font-weight-semibold);
        color: var(--color-text-primary);
        line-height: var(--line-height-tight);
        flex: 1;
        min-width: 0;
        margin-right: var(--space-sm);
      }

      .task-id {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
        white-space: nowrap;
      }

      .task-stats {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin: var(--space-sm) 0;
      }

      .task-count {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-sm);
        color: var(--color-text-secondary);
      }

      .task-percent {
        font-family: var(--font-family-mono);
        font-weight: var(--font-weight-bold);
      }

      .task-percent.blue { color: var(--color-primary); text-shadow: 0 0 8px rgba(0,229,255,0.5); }
      .task-percent.gray { color: var(--color-text-tertiary); }
      .task-percent.green { color: var(--color-success); text-shadow: 0 0 8px rgba(0,255,148,0.5); }

      .task-liquid-bar {
        margin: var(--space-sm) 0 var(--space-md);
      }

      .task-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .task-time {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
      }

      .status-badge {
        padding: 3px 10px;
        border-radius: var(--radius-full);
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-medium);
      }

      .status-badge.blue {
        background: var(--color-primary-faint);
        border: 1px solid rgba(0, 229, 255, 0.3);
        color: var(--color-primary);
        text-shadow: 0 0 6px rgba(0, 229, 255, 0.4);
      }

      .status-badge.gray {
        background: rgba(232, 236, 244, 0.08);
        border: 1px solid rgba(232, 236, 244, 0.15);
        color: var(--color-text-tertiary);
      }

      .status-badge.green {
        background: var(--color-success-faint);
        border: 1px solid rgba(0, 255, 148, 0.3);
        color: var(--color-success);
        text-shadow: 0 0 6px rgba(0, 255, 148, 0.4);
      }

      /* ====== 3. DIFFERENCE RESULT SECTION ====== */
      .diff-section {
        padding: var(--space-lg);
        margin-bottom: var(--space-xl);
        position: relative;
        overflow: hidden;
      }

      .diff-section-title {
        font-family: var(--font-family-display);
        font-size: var(--font-size-lg);
        color: var(--color-secondary);
        text-shadow: 0 0 8px rgba(255, 184, 0, 0.5);
        margin-bottom: var(--space-lg);
      }

      /* Scanning line effect */
      .scan-line-effect {
        position: absolute;
        left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255, 184, 0, 0.15), transparent);
        animation: scan-line-move 4s linear infinite;
        pointer-events: none;
        z-index: 1;
      }

      @keyframes scan-line-move {
        0% { top: 0; opacity: 0; }
        5% { opacity: 1; }
        95% { opacity: 1; }
        100% { top: 100%; opacity: 0; }
      }

      .diff-tabs {
        display: flex;
        gap: var(--space-sm);
        margin-bottom: var(--space-lg);
        position: relative;
        z-index: 2;
      }

      .diff-tab {
        padding: 8px 20px;
        border-radius: var(--radius-md);
        font-size: var(--font-size-md);
        font-weight: var(--font-weight-medium);
        cursor: pointer;
        transition: all var(--transition-normal);
        border: 1px solid var(--color-border-subtle);
        background: rgba(13, 19, 33, 0.4);
        color: var(--color-text-secondary);
      }

      .diff-tab:hover {
        background: rgba(0, 229, 255, 0.06);
        border-color: var(--color-border-hover);
      }

      .diff-tab.active-consistent {
        background: var(--color-success-faint);
        border: 1px solid rgba(0, 255, 148, 0.3);
        color: var(--color-success);
        text-shadow: 0 0 6px rgba(0, 255, 148, 0.4);
        box-shadow: 0 0 10px rgba(0, 255, 148, 0.15);
      }

      .diff-tab.active-surplus {
        background: var(--color-primary-faint);
        border: 1px solid rgba(0, 229, 255, 0.3);
        color: var(--color-primary);
        text-shadow: 0 0 6px rgba(0, 229, 255, 0.4);
        box-shadow: 0 0 10px rgba(0, 229, 255, 0.15);
      }

      .diff-tab.active-loss {
        background: var(--color-danger-faint);
        border: 1px solid rgba(255, 46, 99, 0.3);
        color: var(--color-danger);
        text-shadow: 0 0 6px rgba(255, 46, 99, 0.4);
        box-shadow: 0 0 10px rgba(255, 46, 99, 0.15);
        animation: loss-tab-glow 1.5s ease-in-out infinite;
      }

      @keyframes loss-tab-glow {
        0%, 100% { box-shadow: 0 0 10px rgba(255, 46, 99, 0.15); }
        50% { box-shadow: 0 0 20px rgba(255, 46, 99, 0.35), 0 0 40px rgba(255, 46, 99, 0.15); }
      }

      .diff-tab-count {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        margin-left: 6px;
        opacity: 0.8;
      }

      .diff-content {
        position: relative;
        z-index: 2;
      }

      .diff-category {
        display: none;
      }

      .diff-category.active {
        display: block;
      }

      .diff-category-header {
        padding: var(--space-sm) var(--space-md);
        border-radius: var(--radius-md);
        font-size: var(--font-size-sm);
        font-weight: var(--font-weight-semibold);
        margin-bottom: var(--space-md);
        letter-spacing: var(--letter-spacing-wide);
      }

      .diff-category-header.green {
        background: var(--color-success-faint);
        border: 1px solid rgba(0, 255, 148, 0.2);
        color: var(--color-success);
      }

      .diff-category-header.blue {
        background: var(--color-primary-faint);
        border: 1px solid rgba(0, 229, 255, 0.2);
        color: var(--color-primary);
      }

      .diff-category-header.red {
        background: var(--color-danger-faint);
        border: 1px solid rgba(255, 46, 99, 0.2);
        color: var(--color-danger);
        animation: loss-header-glow 2s ease-in-out infinite;
      }

      @keyframes loss-header-glow {
        0%, 100% {
          box-shadow: 0 0 8px rgba(255, 46, 99, 0.2);
        }
        50% {
          box-shadow: 0 0 16px rgba(255, 46, 99, 0.5), 0 0 32px rgba(255, 46, 99, 0.2);
        }
      }

      /* Loss rows red highlight flash */
      .loss-row {
        animation: red-flash 3s ease-in-out infinite;
      }

      @keyframes red-flash {
        0%, 100% { background: rgba(255, 46, 99, 0.02); }
        50% { background: rgba(255, 46, 99, 0.08); }
      }

      /* ====== 4. ACTION BAR ====== */
      .action-bar {
        display: flex;
        justify-content: flex-end;
        gap: var(--space-md);
        padding: var(--space-lg) 0;
        border-top: 1px solid var(--color-border-subtle);
        margin-top: var(--space-lg);
      }

      .action-btn {
        padding: 10px 24px;
        border-radius: var(--radius-md);
        font-size: var(--font-size-md);
        font-weight: var(--font-weight-medium);
        cursor: pointer;
        transition: all var(--transition-normal);
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .action-btn-gold {
        background: linear-gradient(135deg, rgba(255, 184, 0, 0.2), rgba(255, 184, 0, 0.1));
        border: 1px solid var(--color-secondary);
        color: var(--color-secondary);
        box-shadow: var(--glow-secondary);
        text-shadow: 0 0 8px rgba(255, 184, 0, 0.5);
      }
      .action-btn-gold:hover {
        background: linear-gradient(135deg, rgba(255, 184, 0, 0.3), rgba(255, 184, 0, 0.2));
        box-shadow: 0 0 15px rgba(255, 184, 0, 0.6), 0 0 30px rgba(255, 184, 0, 0.3);
        transform: translateY(-2px);
      }

      .action-btn-blue {
        background: linear-gradient(135deg, rgba(0, 229, 255, 0.2), rgba(0, 229, 255, 0.1));
        border: 1px solid var(--color-primary);
        color: var(--color-primary);
        box-shadow: var(--glow-primary);
        text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
      }
      .action-btn-blue:hover {
        background: linear-gradient(135deg, rgba(0, 229, 255, 0.3), rgba(0, 229, 255, 0.2));
        box-shadow: 0 0 15px rgba(0, 229, 255, 0.6), 0 0 30px rgba(0, 229, 255, 0.3);
        transform: translateY(-2px);
      }

      .action-btn-green {
        background: linear-gradient(135deg, rgba(0, 255, 148, 0.2), rgba(0, 255, 148, 0.1));
        border: 1px solid var(--color-success);
        color: var(--color-success);
        box-shadow: var(--glow-success);
        text-shadow: 0 0 8px rgba(0, 255, 148, 0.5);
      }
      .action-btn-green:hover {
        background: linear-gradient(135deg, rgba(0, 255, 148, 0.3), rgba(0, 255, 148, 0.2));
        box-shadow: 0 0 15px rgba(0, 255, 148, 0.6), 0 0 30px rgba(0, 255, 148, 0.3);
        transform: translateY(-2px);
      }

      /* ====== ANIMATED COUNTER ====== */
      @keyframes counter-up {
        from { opacity: 0; transform: translateY(6px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .counter-animated {
        display: inline-block;
        animation: counter-up 0.8s ease-out forwards;
      }
    </style>
</body>
