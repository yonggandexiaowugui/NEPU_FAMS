    <script>
      // Tab switching logic
      function switchDiffTab(tab) {
        // Remove all active classes from tabs
        document.querySelectorAll('.diff-tab').forEach(t => {
          t.className = 'diff-tab';
        });
        // Hide all categories
        document.querySelectorAll('.diff-category').forEach(c => {
          c.classList.remove('active');
        });
        // Activate selected tab and content
        const tabEl = event.currentTarget;
        const contentEl = document.getElementById('diff-' + tab);
        if (tab === 'consistent') {
          tabEl.classList.add('active-consistent');
        } else if (tab === 'surplus') {
          tabEl.classList.add('active-surplus');
        } else if (tab === 'loss') {
          tabEl.classList.add('active-loss');
        }
        contentEl.classList.add('active');
      }

      // Animated counters
      function animateCounters() {
        document.querySelectorAll('.counter-animated').forEach(el => {
          const target = parseInt(el.textContent);
          let current = 0;
          const step = Math.max(1, Math.floor(target / 30));
          const interval = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(interval);
            }
            el.textContent = current;
          }, 40);
        });
      }

      // Run on load
      document.addEventListener('DOMContentLoaded', () => {
        animateCounters();
      });

      lucide.createIcons();
    </script>
