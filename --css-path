  @theme inline {
    --color-primary: var(--color-primary);
    --color-secondary: var(--color-secondary);
  }
  @layer base {
    body { background: var(--color-bg-primary); color: var(--color-text-primary); }
    td, th { @apply break-words; word-break: break-all; word-break: auto-phrase; }
