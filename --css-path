    <style id="theme-vars">
/* NEPU-FAMS Design System - Cyberpunk Sci-Fi Admin Console */
/* Brand CSS Variables */

:root {
  /* === Core Background System === */
  --color-bg-primary: #080C16;
  --color-bg-secondary: #0D1321;
  --color-bg-tertiary: #111827;
  --color-bg-card: rgba(13, 19, 33, 0.7);
  --color-bg-card-hover: rgba(17, 24, 39, 0.85);
  --color-bg-glass: rgba(13, 19, 33, 0.6);
  --color-bg-overlay: rgba(8, 12, 22, 0.85);
  --color-bg-input: rgba(13, 19, 33, 0.8);

  /* === Primary Brand - Electric Petroleum Blue === */
  --color-primary: #00E5FF;
  --color-primary-rgb: 0, 229, 255;
  --color-primary-dim: rgba(0, 229, 255, 0.6);
  --color-primary-faint: rgba(0, 229, 255, 0.15);
  --color-primary-glow: rgba(0, 229, 255, 0.4);
  --color-primary-dark: #00B8CC;
  --color-primary-light: #33EBFF;

  /* === Secondary Brand - Neon Industrial Gold === */
  --color-secondary: #FFB800;
  --color-secondary-rgb: 255, 184, 0;
  --color-secondary-dim: rgba(255, 184, 0, 0.6);
  --color-secondary-faint: rgba(255, 184, 0, 0.15);
  --color-secondary-glow: rgba(255, 184, 0, 0.4);

  /* === Functional Colors === */
  --color-success: #00FF94;
  --color-success-rgb: 0, 255, 148;
  --color-success-dim: rgba(0, 255, 148, 0.6);
  --color-success-faint: rgba(0, 255, 148, 0.15);
  --color-success-glow: rgba(0, 255, 148, 0.4);

  --color-warning: #FF8A00;
  --color-warning-rgb: 255, 138, 0;
  --color-warning-dim: rgba(255, 138, 0, 0.6);
  --color-warning-faint: rgba(255, 138, 0, 0.15);
  --color-warning-glow: rgba(255, 138, 0, 0.4);

  --color-danger: #FF2E63;
  --color-danger-rgb: 255, 46, 99;
  --color-danger-dim: rgba(255, 46, 99, 0.6);
  --color-danger-faint: rgba(255, 46, 99, 0.15);
  --color-danger-glow: rgba(255, 46, 99, 0.4);

  --color-info: #00E5FF;

  /* === Text Colors === */
  --color-text-primary: #E8ECF4;
  --color-text-secondary: rgba(232, 236, 244, 0.7);
  --color-text-tertiary: rgba(232, 236, 244, 0.45);
  --color-text-disabled: rgba(232, 236, 244, 0.25);
  --color-text-inverse: #080C16;
  --color-text-link: #00E5FF;
  --color-text-glow: rgba(232, 236, 244, 0.9);

  /* === Border Colors === */
  --color-border-primary: rgba(0, 229, 255, 0.2);
  --color-border-hover: rgba(0, 229, 255, 0.4);
  --color-border-focus: rgba(0, 229, 255, 0.6);
  --color-border-subtle: rgba(232, 236, 244, 0.08);
  --color-border-glass: rgba(0, 229, 255, 0.12);

  /* === Glow / Neon Effects === */
  --glow-primary: 0 0 10px rgba(0, 229, 255, 0.5), 0 0 20px rgba(0, 229, 255, 0.2);
  --glow-secondary: 0 0 10px rgba(255, 184, 0, 0.5), 0 0 20px rgba(255, 184, 0, 0.2);
  --glow-success: 0 0 10px rgba(0, 255, 148, 0.5), 0 0 20px rgba(0, 255, 148, 0.2);
  --glow-danger: 0 0 10px rgba(255, 46, 99, 0.5), 0 0 20px rgba(255, 46, 99, 0.2);
  --glow-warning: 0 0 10px rgba(255, 138, 0, 0.5), 0 0 20px rgba(255, 138, 0, 0.2);

  /* === Glass Effect === */
  --glass-blur: blur(16px);
  --glass-blur-heavy: blur(24px);
  --glass-bg: rgba(13, 19, 33, 0.65);
  --glass-border: 1px solid rgba(0, 229, 255, 0.12);
  --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(0, 229, 255, 0.06);

  /* === Radius System === */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-full: 9999px;

  /* === Spacing === */
  --space-xs: 4px;
  --space-sm: 8px;
  --space-md: 16px;
  --space-lg: 24px;
  --space-xl: 32px;
  --space-2xl: 48px;
  --space-3xl: 64px;

  /* === Typography === */
  --font-family-display: 'Orbitron', 'Rajdhani', 'Microsoft YaHei', sans-serif;
  --font-family-body: 'Inter', 'Microsoft YaHei', 'PingFang SC', sans-serif;
  --font-family-mono: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;

  --font-size-xs: 11px;
  --font-size-sm: 12px;
  --font-size-base: 13px;
  --font-size-md: 14px;
  --font-size-lg: 16px;
  --font-size-xl: 20px;
  --font-size-2xl: 24px;
  --font-size-3xl: 32px;
  --font-size-4xl: 40px;
  --font-size-5xl: 48px;

  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  --line-height-tight: 1.25;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.75;

  --letter-spacing-tight: -0.02em;
  --letter-spacing-normal: 0;
  --letter-spacing-wide: 0.05em;
  --letter-spacing-wider: 0.1em;

  /* === Shadow System === */
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.35);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.4);
  --shadow-xl: 0 16px 48px rgba(0, 0, 0, 0.5);
  --shadow-card: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(0, 229, 255, 0.06);
  --shadow-float: 0 16px 48px rgba(0, 0, 0, 0.6), 0 0 30px rgba(0, 229, 255, 0.1);

  /* === Sidebar === */
  --sidebar-width: 240px;
  --sidebar-collapsed-width: 64px;
  --sidebar-bg: rgba(8, 12, 22, 0.95);

  /* === Header === */
  --header-height: 56px;
  --header-bg: rgba(8, 12, 22, 0.8);

  /* === Transitions === */
  --transition-fast: 150ms ease;
  --transition-normal: 250ms ease;
  --transition-slow: 400ms ease;
  --transition-bounce: 300ms cubic-bezier(0.34, 1.56, 0.64, 1);

  /* === Z-Index Scale === */
  --z-sidebar: 100;
  --z-header: 200;
  --z-dropdown: 300;
  --z-modal-backdrop: 400;
  --z-modal: 500;
  --z-toast: 600;
  --z-tooltip: 700;
}

/* === Global Base Styles === */
html {
  font-size: var(--font-size-base);
  line-height: var(--line-height-normal);
  color: var(--color-text-primary);
  background-color: var(--color-bg-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-family-body);
  background: var(--color-bg-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

/* === Utility Classes === */
.text-glow {
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.6), 0 0 16px rgba(0, 229, 255, 0.3);
}

.text-glow-gold {
  text-shadow: 0 0 8px rgba(255, 184, 0, 0.6), 0 0 16px rgba(255, 184, 0, 0.3);
}

.glass-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: var(--glass-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.glass-card-hover:hover {
  background: var(--color-bg-card-hover);
  border-color: var(--color-border-hover);
  box-shadow: var(--shadow-card), var(--glow-primary);
  transform: translateY(-2px) scale(1.02);
  transition: all var(--transition-normal);
}

.neon-border {
  border: 1px solid var(--color-border-primary);
  box-shadow: var(--glow-primary);
}

.neon-border-gold {
  border: 1px solid rgba(255, 184, 0, 0.3);
  box-shadow: var(--glow-secondary);
}

.neon-text {
  color: var(--color-primary);
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
}

.neon-btn {
  background: linear-gradient(135deg, rgba(0, 229, 255, 0.2), rgba(0, 229, 255, 0.1));
  border: 1px solid var(--color-primary);
  color: var(--color-primary);
  padding: 8px 20px;
  border-radius: var(--radius-md);
  font-weight: var(--font-weight-medium);
  cursor: pointer;
  transition: all var(--transition-normal);
  box-shadow: var(--glow-primary);
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
}

.neon-btn:hover {
  background: linear-gradient(135deg, rgba(0, 229, 255, 0.3), rgba(0, 229, 255, 0.2));
  box-shadow: 0 0 15px rgba(0, 229, 255, 0.6), 0 0 30px rgba(0, 229, 255, 0.3);
  transform: translateY(-2px);
}

.neon-btn-gold {
  background: linear-gradient(135deg, rgba(255, 184, 0, 0.2), rgba(255, 184, 0, 0.1));
  border: 1px solid var(--color-secondary);
  color: var(--color-secondary);
  box-shadow: var(--glow-secondary);
  text-shadow: 0 0 8px rgba(255, 184, 0, 0.5);
}

.neon-btn-gold:hover {
  background: linear-gradient(135deg, rgba(255, 184, 0, 0.3), rgba(255, 184, 0, 0.2));
  box-shadow: 0 0 15px rgba(255, 184, 0, 0.6), 0 0 30px rgba(255, 184, 0, 0.3);
}

.neon-btn-danger {
  background: linear-gradient(135deg, rgba(255, 46, 99, 0.2), rgba(255, 46, 99, 0.1));
  border: 1px solid var(--color-danger);
  color: var(--color-danger);
  box-shadow: var(--glow-danger);
}

/* === Neon Status Badges === */
.status-idle {
  background: var(--color-success-faint);
  border: 1px solid rgba(0, 255, 148, 0.3);
  color: var(--color-success);
  text-shadow: 0 0 6px rgba(0, 255, 148, 0.4);
}

.status-in-use {
  background: var(--color-warning-faint);
  border: 1px solid rgba(255, 138, 0, 0.3);
  color: var(--color-warning);
  text-shadow: 0 0 6px rgba(255, 138, 0, 0.4);
}

.status-repair {
  background: rgba(255, 184, 0, 0.15);
  border: 1px solid rgba(255, 184, 0, 0.3);
  color: var(--color-secondary);
  text-shadow: 0 0 6px rgba(255, 184, 0, 0.4);
}

.status-scrapped {
  background: var(--color-danger-faint);
  border: 1px solid rgba(255, 46, 99, 0.3);
  color: var(--color-danger);
  text-shadow: 0 0 6px rgba(255, 46, 99, 0.4);
}

.status-loss {
  background: rgba(232, 236, 244, 0.08);
  border: 1px solid rgba(232, 236, 244, 0.15);
  color: var(--color-text-tertiary);
}

/* === Table Styles === */
.cyber-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.cyber-table thead th {
  background: rgba(0, 229, 255, 0.08);
  border-bottom: 1px solid var(--color-border-primary);
  color: var(--color-primary);
  font-weight: var(--font-weight-semibold);
  font-size: var(--font-size-sm);
  text-transform: uppercase;
  letter-spacing: var(--letter-spacing-wider);
  padding: 12px 16px;
  text-align: left;
}

.cyber-table tbody tr {
  border-bottom: 1px solid var(--color-border-subtle);
  transition: all var(--transition-fast);
}

.cyber-table tbody tr:hover {
  background: rgba(0, 229, 255, 0.05);
  box-shadow: inset 0 0 20px rgba(0, 229, 255, 0.03);
}

.cyber-table tbody td {
  padding: 12px 16px;
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
}

/* === Scrollbar === */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: var(--color-bg-primary);
}

::-webkit-scrollbar-thumb {
  background: rgba(0, 229, 255, 0.2);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 229, 255, 0.4);
}

/* === Animations === */
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 8px rgba(0, 229, 255, 0.4); }
  50% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.8), 0 0 40px rgba(0, 229, 255, 0.3); }
}

@keyframes breathe {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes float-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scan-line {
  0% { top: 0; }
  100% { top: 100%; }
}

@keyframes liquid-wave {
  0% { border-radius: 40% 60% 60% 40% / 60% 30% 70% 40%; }
  50% { border-radius: 60% 40% 30% 70% / 30% 60% 40% 60%; }
  100% { border-radius: 40% 60% 60% 40% / 60% 30% 70% 40%; }
}

@keyframes neon-flow {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes counter-scroll {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes ripple {
  0% { transform: scale(0); opacity: 0.6; }
  100% { transform: scale(4); opacity: 0; }
}

.animate-float-up {
  animation: float-up 0.6s ease-out forwards;
}

.animate-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

.animate-breathe {
  animation: breathe 3s ease-in-out infinite;
}

/* === Input Focus === */
.cyber-input {
  background: var(--color-bg-input);
  border: 1px solid var(--color-border-subtle);
  border-radius: var(--radius-md);
  color: var(--color-text-primary);
  padding: 8px 14px;
  font-size: var(--font-size-base);
  transition: all var(--transition-normal);
  outline: none;
}

.cyber-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 10px rgba(0, 229, 255, 0.3), 0 0 20px rgba(0, 229, 255, 0.1);
}

.cyber-input::placeholder {
  color: var(--color-text-tertiary);
}

