        background: var(--color-primary-faint);
        border: 1px solid rgba(0, 229, 255, 0.3);
        color: var(--color-primary);
        text-shadow: 0 0 4px rgba(0, 229, 255, 0.3);
      }
      .log-type-badge.delete {
        background: var(--color-danger-faint);
        border: 1px solid rgba(255, 46, 99, 0.3);
        color: var(--color-danger);
        text-shadow: 0 0 4px rgba(255, 46, 99, 0.3);
      }
      .log-type-badge.approve {
        background: var(--color-secondary-faint);
        border: 1px solid rgba(255, 184, 0, 0.3);
        color: var(--color-secondary);
        text-shadow: 0 0 4px rgba(255, 184, 0, 0.3);
      }
      .log-type-badge.export {
        background: rgba(0, 229, 255, 0.1);
        border: 1px solid rgba(0, 229, 255, 0.25);
        color: #00E5FF;
        text-shadow: 0 0 4px rgba(0, 229, 255, 0.3);
      }
      .log-type-badge.login {
        background: rgba(179, 136, 255, 0.12);
        border: 1px solid rgba(179, 136, 255, 0.3);
        color: #B388FF;
        text-shadow: 0 0 4px rgba(179, 136, 255, 0.3);
      }

      /* Operator name */
      .log-operator {
        color: var(--color-text-primary);
        text-shadow: 0 0 6px rgba(232, 236, 244, 0.15);
        font-weight: var(--font-weight-medium);
      }

      /* IP address */
      .log-ip {
        font-family: var(--font-family-mono);
        font-size: var(--font-size-xs);
        color: var(--color-text-tertiary);
      }

      /* Content text */
      .log-content {
        color: var(--color-text-secondary);
        max-width: 320px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* View detail link */
      .log-view-link {
        color: var(--color-primary);
        font-size: var(--font-size-xs);
        font-weight: var(--font-weight-medium);
