      .terminal-header {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: 12px var(--space-lg);
        border-bottom: 1px solid rgba(0, 229, 255, 0.1);
        background: rgba(0, 229, 255, 0.03);
