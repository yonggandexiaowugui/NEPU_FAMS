        }

        /* === Particle Field === */
        .particles {
            position: absolute;
            inset: 0;
            z-index: 1;
            overflow: hidden;
        }

        .particles span {
            position: absolute;
            left: var(--x);
            top: var(--y);
            width: var(--size);
            height: var(--size);
            background: var(--color-primary);
            border-radius: 50%;
            opacity: var(--opacity);
            box-shadow: 0 0 6px var(--color-primary-glow);
            animation: particle-float var(--duration) linear var(--delay) infinite;
        }

        @keyframes particle-float {
            0% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }
            10% {
                opacity: var(--opacity);
            }
            50% {
                transform: translate(80px, -120px) scale(1.3);
            }
            90% {
                opacity: var(--opacity);
            }
            100% {
                transform: translate(160px, -240px) scale(0.5);
                opacity: 0;
            }
        }

        /* === Hologram Area (Center-Left) === */
