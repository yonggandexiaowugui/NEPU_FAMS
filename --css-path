                transparent);
        }

        .footer-text {
            font-family: var(--font-family-body);
            font-size: 11px;
            font-weight: 400;
            color: var(--color-text-tertiary);
            letter-spacing: 0.12em;
            text-shadow: 0 0 6px rgba(0, 229, 255, 0.15);
        }

        /* === Corner Decorations === */
        .corner-deco {
            position: absolute;
            width: 40px;
            height: 40px;
            z-index: 3;
            pointer-events: none;
        }

        .corner-tl {
            top: 30px;
            left: 30px;
            border-top: 2px solid rgba(0, 229, 255, 0.25);
            border-left: 2px solid rgba(0, 229, 255, 0.25);
        }

        .corner-tr {
            top: 30px;
            right: 30px;
            border-top: 2px solid rgba(0, 229, 255, 0.25);
            border-right: 2px solid rgba(0, 229, 255, 0.25);
        }

        .corner-bl {
            bottom: 30px;
            left: 30px;
            border-bottom: 2px solid rgba(255, 184, 0, 0.15);
            border-left: 2px solid rgba(255, 184, 0, 0.15);
        }

        .corner-br {
            bottom: 30px;
            right: 30px;
            border-bottom: 2px solid rgba(255, 184, 0, 0.15);
            border-right: 2px solid rgba(255, 184, 0, 0.15);
        }

        /* === Additional Ambient Effects === */
        .login-card::before {
            content: '';
            position: absolute;
            top: -1px;
            left: 20%;
            right: 20%;
            height: 1px;
            background: linear-gradient(90deg,
                transparent,
                rgba(0, 229, 255, 0.6),
                transparent);
            animation: top-glow 3s ease-in-out infinite;
        }

        .login-card::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 30%;
            right: 30%;
            height: 1px;
            background: linear-gradient(90deg,
                transparent,
                rgba(255, 184, 0, 0.3),
                transparent);
            animation: bottom-glow 4s ease-in-out infinite;
        }

        @keyframes top-glow {
            0%, 100% { opacity: 0.4; }
            50% { opacity: 1; }
        }

        @keyframes bottom-glow {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.8; }
        }

        /* Hologram ambient glow on the ground */
        .hologram-area::after {
            content: '';
            position: absolute;
            bottom: -80px;
            left: 50%;
            transform: translateX(-50%);
            width: 200px;
            height: 4px;
            background: radial-gradient(ellipse, rgba(0, 229, 255, 0.3), transparent);
            animation: ground-glow 4s ease-in-out infinite;
        }

        @keyframes ground-glow {
            0%, 100% { opacity: 0.5; transform: translateX(-50%) scaleX(1); }
            50% { opacity: 1; transform: translateX(-50%) scaleX(1.2); }
        }
